# Java Recursion

- Example:-

    import java.util.Scanner;
    
    class Main {
    
        static int fect(int n){
            if(0<n){
                System.out.print( " "+n+" " );
                return n * fect(n - 1);
            }else{
                return 1;
            }
        }
        public static void main(String argc[]) {
            Scanner sc =  new Scanner(System.in);
    
            System.out.print("Enter The Number:");
            int n = sc.nextInt();
    
            System.out.print("factorial is : " + fect(n));
    
        }
    }

